# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Get from: Vercel Storage → Neon → Connect → .env.local
DATABASE_URL=postgres://user:password@host.neon.tech/shopsalida?sslmode=require

# ── Auth (JWT) ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET=your-32-char-minimum-secret-here

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# CEO notification email (receives new signup & listing alerts)
RESEND_CEO_EMAIL=CEO@epicai.ai

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE

# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# Create products in Stripe Dashboard, copy price IDs here
STRIPE_PRICE_PREMIUM=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_SPONSORED=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Public env vars (safe to expose to browser) ───────────────────────────────
NEXT_PUBLIC_URL=https://shopsalida.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY_HERE

# ── Dev overrides ─────────────────────────────────────────────────────────────
# For local dev:
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_PREMIUM=price_test_...
# STRIPE_PRICE_SPONSORED=price_test_...
# NEXT_PUBLIC_URL=http://localhost:3000

# Google Analytics 4 — add your Measurement ID from analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Ads conversion tracking (optional)
NEXT_PUBLIC_GADS_ID=
